@model OrderDetailViewModel

@{
    ViewData["Title"] = "MyOrderDetail";
    Layout = "~/Areas/User/Views/UserLayout/_UserLayout.cshtml";

    var cargoInfo = ViewBag.CargoDetail as ResultCargoDetailDto;
    var cargoSteps = ViewBag.CargoOperations as List<ResultCargoOperationDto>;
    // Controller'dan gelen Firma Adı
    var cargoCompanyName = ViewBag.CargoCompanyName as string;
}

<style>
    /* Üst Kart Tasarımı */
    .order-header-card {
        background-color: #1a1a1a;
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 25px;
        border: 1px solid #333;
    }

    .text-warning-custom {
        color: #ffc107;
    }

    /* --- BUTON GRUBU DÜZENİ (DÜZELTİLDİ) --- */
    .action-group {
        display: flex;
        width: 100%; /* Genişliği tam kapla */
        justify-content: flex-end; /* İçeriği zorla sağa yasla */
        align-items: center; /* Dikeyde ortala */
        gap: 15px; /* Butonlar arası sabit boşluk */
    }

    /* Timeline Tasarımı */
    .timeline {
        border-left: 3px solid #5e72e4;
        margin-left: 20px;
        padding-left: 20px;
        list-style: none;
    }

    .timeline-item {
        position: relative;
        margin-bottom: 25px;
    }

        .timeline-item::before {
            content: "";
            position: absolute;
            left: -29px;
            top: 0;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background-color: #5e72e4;
            border: 3px solid #fff;
        }

    .timeline-content {
        background-color: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
        border-left: 4px solid #5e72e4;
        color: #333;
    }

    /* Tablo Renk Standartları */
    .table-dark {
        background-color: #1a1a1a !important;
    }

    .bg-black {
        background-color: #000 !important;
    }
</style>

<div class="container my-5">

    @if (!string.IsNullOrEmpty(Model.RefundNote))
    {
        <div class="alert alert-info shadow-sm mb-4">@Html.Raw(Model.RefundNote)</div>
    }

    @* Üst Panel *@
    <div class="order-header-card">
        <div class="row align-items-center">
            @* SOL: Sipariş Bilgileri *@
            <div class="col-lg-5">
                <h4 class="mb-1 text-white">Sipariş No: <span class="text-warning-custom">#@Model.OrderNumber</span></h4>
                <p class="mb-0 text-muted">
                    <i class="fa fa-calendar-o me-2"></i>@Model.OrderDate.ToString("dd MMMM yyyy, dddd HH:mm", new System.Globalization.CultureInfo("tr-TR"))
                </p>
            </div>

            @* SAĞ: Butonlar *@
            <div class="col-lg-7 mt-3 mt-lg-0">
                @* action-group sınıfı ile her şey sağa yaslandı *@
                <div class="action-group">

                    @* 1. Grup: Statü Rozetleri ve İade (Sola gelir) *@
                    @if (Model.Status == 3) // Teslim Edildi
                    {
                        <span class="badge bg-success text-white px-3 py-2 rounded-pill shadow-sm" style="min-width: 120px;">
                            <i class="fa fa-check-circle me-1"></i> Teslim Edildi
                        </span>

                        <a href="/User/MyOrder/RequestRefund/@Model.OrderingId" class="btn btn-outline-danger rounded-pill px-4 py-2 shadow-sm">
                            <i class="fa fa-reply me-2"></i> İade Talebi
                        </a>
                    }
                    else if (Model.Status == 1)
                    {
                        <span class="badge bg-danger text-white px-3 py-2 rounded-pill">İptal Edildi</span>
                    }

                    @* 2. Grup: Kargo Detayları (DOM sırasına göre en sonda olduğu için EN SAĞDA durur) *@
                    @if (cargoInfo != null)
                    {
                        <button type="button" class="btn btn-primary shadow-sm px-4 py-2"
                                style="background-color: #5e72e4; border:none;"
                                data-bs-toggle="modal"
                                data-bs-target="#cargoModal">
                            <i class="fa fa-truck me-2"></i> Kargo Detayları
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Sipariş İçeriği Tablosu *@
    <div class="card shadow-sm border-0 bg-dark text-white mb-4">
        <div class="card-header bg-transparent border-secondary py-3">
            <h5 class="mb-0 fw-bold"><i class="fa fa-shopping-basket me-2 text-warning-custom"></i> Sipariş İçeriği</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead class="text-muted">
                        <tr>
                            <th class="ps-4 py-3 border-0">Ürün</th>
                            <th class="text-center py-3 border-0">Adet</th>
                            <th class="text-end py-3 border-0">Birim Fiyat</th>
                            <th class="text-end pe-4 py-3 border-0">Toplam</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.OrderDetails != null)
                        {
                            foreach (var item in Model.OrderDetails)
                            {
                                <tr class="border-secondary">
                                    <td class="ps-4 fw-bold border-0">@item.ProductName</td>
                                    <td class="text-center border-0">@item.ProductAmount</td>
                                    <td class="text-end text-muted border-0">@item.ProductPrice.ToString("N2") ₺</td>
                                    <td class="text-end pe-4 fw-bold text-warning-custom border-0">@((item.ProductPrice * item.ProductAmount).ToString("N2")) ₺</td>
                                </tr>
                            }
                        }
                    </tbody>
                    <tfoot class="bg-black">
                        <tr>
                            <td colspan="3" class="text-end py-4 border-0">
                                <span class="text-muted fw-bold">Genel Toplam:</span>
                            </td>
                            <td class="text-end pe-4 py-4 border-0">
                                <span class="fs-4 fw-bold text-warning-custom">@Model.TotalPrice.ToString("N2") ₺</span>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
        <div class="card-footer bg-transparent border-top border-secondary d-flex justify-content-end gap-2 py-3">
            @if (Model.Status == 0)
            {
                <form id="cancelOrderForm" action="/User/MyOrder/CancelOrder" method="post">
                    <input type="hidden" name="orderingId" value="@Model.OrderingId" />
                    <button type="button" id="btnCancelOrder" class="btn btn-outline-danger px-4">Siparişi İptal Et</button>
                </form>
            }
            <a href="/User/MyOrder/MyOrderList" class="btn btn-outline-light px-4">Listeye Dön</a>
        </div>
    </div>
</div>

@* KARGO TAKİP MODALI *@
@if (cargoInfo != null)
{
    <div class="modal fade" id="cargoModal" tabindex="-1" aria-labelledby="cargoModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title text-dark" id="cargoModalLabel">
                        <i class="fa fa-truck text-primary me-2"></i> Kargo Hareketleri
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-4 p-3 bg-light rounded d-flex justify-content-between align-items-center">
                        <span class="text-dark">Firma: <strong>@(cargoCompanyName ?? "Aras Kargo")</strong></span>
                        <span class="text-dark">Takip No: <strong class="text-primary font-monospace">@cargoInfo.Barcode</strong></span>
                    </div>

                    @if (cargoSteps != null && cargoSteps.Count > 0)
                    {
                        <ul class="timeline">
                            @foreach (var item in cargoSteps.OrderByDescending(x => x.OperationDate))
                            {
                                <li class="timeline-item">
                                    <div class="timeline-date">@item.OperationDate.ToString("dd MMMM yyyy - HH:mm")</div>
                                    <div class="timeline-content">
                                        <strong>@item.Description</strong>
                                        <p class="mb-0 text-muted small">İşlem kaydedildi.</p>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>