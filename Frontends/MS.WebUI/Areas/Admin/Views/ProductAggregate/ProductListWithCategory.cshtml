@model List<UpdateProductFullDto>

@{
    ViewData["Title"] = "ProductListWithCategory";
    Layout = "~/Areas/Admin/Views/AdminLayout/_AdminLayout.cshtml";
    int count = 0;
}

<section class="content container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="chart-box">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th class="text-center">Ana Görsel</th>
                            <th class="text-center">Ürün Adı</th>
                            <th class="text-center">Kategori</th>
                            <th class="text-center">Fiyat</th>
                            <th class="text-center">Detay</th>
                            <th class="text-center" style="width: 200px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <th scope="row" style="vertical-align: middle; text-align: center;">@count</th>

                                <td style="vertical-align: middle; text-align: center;">
                                    @if (!string.IsNullOrEmpty(item.ProductImageUrl))
                                    {
                                        <img src="@item.ProductImageUrl" style="width:75px; height:75px; object-fit:cover; border-radius:5px; border:1px solid #ddd;" alt="Ürün" />
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">Görsel Yok</span>
                                    }
                                </td>

                                <td style="vertical-align: middle; text-align: center;">@item.ProductName</td>
                                <td style="vertical-align: middle; text-align: center;">@item.CategoryName</td>
                                <td style="vertical-align: middle; text-align: center;">@item.ProductPrice₺</td>

                                <td style="vertical-align: middle; text-align: center;">
                                    @(item.ProductDescription?.Length > 20 ? item.ProductDescription.Substring(0, 20) + "..." : item.ProductDescription)
                                </td>

                                <td style="vertical-align: middle; text-align: center;">
                                    <div style="display: flex; justify-content: center; align-items: center; gap: 10px;">

                                        <form action="/Admin/ProductAggregate/DeleteProductFull" method="post" style="margin:0;">
                                            <input type="hidden" name="id" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-danger btn-sm"
                                                    onclick="return confirm('Bu ürünü silmek istediğinize emin misiniz?');">
                                                Sil
                                            </button>
                                        </form>

                                        <a href="/Admin/ProductAggregate/UpdateProduct/@item.ProductId" class="btn btn-success btn-sm">
                                            Güncelle
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <a href="/Admin/ProductAggregate/CreateProduct" class="btn btn-primary">Yeni Ürün Girişi</a>
            </div>
        </div>
    </div>
</section>
