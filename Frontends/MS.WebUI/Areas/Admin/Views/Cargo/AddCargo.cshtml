@model CreateCargoDetailDto

@{
    ViewData["Title"] = "AddCargo";
    Layout = "~/Areas/Admin/Views/AdminLayout/_AdminLayout.cshtml";
}

<div class="content-body">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Kargo Bilgisi Gir</h4>
                    </div>
                    <div class="card-body">
                        <div class="basic-form">
                            <form method="post">
                                
                                <input type="hidden" asp-for="OrderingId" value="@ViewBag.OrderingId" />

                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">Takip Barkodu</label>
                                    <div class="col-sm-10">
                                        <input type="text" asp-for="Barcode" value="@ViewBag.Barcode" class="form-control" readonly style="background-color: #eee; cursor: not-allowed;" />
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">Kargo Firması</label>
                                    <div class="col-sm-10">
                                        <select asp-for="CargoCompanyId" asp-items="@ViewBag.CargoCompanies" class="form-control" style="height: 42px;">
                                            <option value="">Lütfen Firma Seçiniz</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">Gönderici (Bayi)</label>
                                    <div class="col-sm-10">
                                        <input type="text" asp-for="SenderCustomer" class="form-control" placeholder="Örn: Mağaza Depo" />
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">Alıcı (Müşteri)</label>
                                    <div class="col-sm-10">
                                        <input type="text" asp-for="ReceiverCustomer" class="form-control" placeholder="Müşteri Adı Soyadı" />
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">Açıklama</label>
                                    <div class="col-sm-10">
                                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Kargo içeriği veya notlar..."></textarea>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <div class="col-sm-10 offset-sm-2">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="fa fa-paper-plane"></i> İşlemi Tamamla ve Kargoya Ver
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>